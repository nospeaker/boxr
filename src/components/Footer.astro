---
import { SITE } from '~/consts';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-slate-200 bg-white py-12 dark:border-slate-800 dark:bg-slate-950">
  <div class="container-wide">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      <div>
        <a href="/" class="flex items-center gap-2 font-bold text-slate-900 dark:text-slate-50">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white">
            <iconify-icon icon="lucide:wrench" width="18" height="18"></iconify-icon>
          </span>
          <span class="text-lg">{SITE.name}</span>
        </a>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">
          {SITE.tagline}. Free, fast, and private.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Tools</h3>
        <ul class="mt-3 space-y-2 text-sm text-slate-600 dark:text-slate-400">
          <li><a class="hover:text-brand-600 dark:hover:text-brand-400" href="/tools/json-formatter">JSON Formatter</a></li>
          <li><a class="hover:text-brand-600 dark:hover:text-brand-400" href="/tools/regex-tester">Regex Tester</a></li>
          <li><a class="hover:text-brand-600 dark:hover:text-brand-400" href="/tools/case-converter">Case Converter</a></li>
          <li><a class="hover:text-brand-600 dark:hover:text-brand-400" href="/tools/lorem-ipsum-generator">Lorem Ipsum</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Company</h3>
        <ul class="mt-3 space-y-2 text-sm text-slate-600 dark:text-slate-400">
          <li><a class="hover:text-brand-600 dark:hover:text-brand-400" href="/about">About</a></li>
          <li><a class="hover:text-brand-600 dark:hover:text-brand-400" href="/blog">Blog</a></li>
          <li><a class="hover:text-brand-600 dark:hover:text-brand-400" href="/contact">Contact</a></li>
          <li><a class="hover:text-brand-600 dark:hover:text-brand-400" href="/privacy">Privacy</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Built with</h3>
        <ul class="mt-3 space-y-2 text-sm text-slate-600 dark:text-slate-400">
          <li class="flex items-center gap-1">
            <iconify-icon icon="lucide:zap" width="14" height="14" class="text-amber-500"></iconify-icon>
            Astro
          </li>
          <li class="flex items-center gap-1">
            <iconify-icon icon="lucide:cloud" width="14" height="14" class="text-sky-500"></iconify-icon>
            Cloudflare Pages
          </li>
          <li>100% in your browser. Zero tracking.</li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-slate-200 pt-6 text-xs text-slate-500 dark:border-slate-800 dark:text-slate-400 sm:flex-row sm:items-center">
      <p>© {year} {SITE.name}. All rights reserved.</p>
      <p class="flex items-center gap-1">
        Made with
        <iconify-icon icon="lucide:heart" class="text-rose-500" width="12" height="12"></iconify-icon>
        for builders.
      </p>
    </div>
  </div>
</footer>
