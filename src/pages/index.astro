---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ToolCard from '~/components/ToolCard.astro';
import { tools, categoryMeta } from '~/config/tools';

const featured = tools.filter((t) => t.featured);
const grouped = Object.entries(categoryMeta).map(([slug, meta]) => ({
  slug,
  meta,
  tools: tools.filter((t) => t.category === slug),
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'UtilHub',
  url: Astro.site?.toString(),
  description: 'Free online developer and text tools. JSON formatter, regex tester, case converter and more — private, fast, no signup.',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${Astro.site}search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="UtilHub"
  description="Free online developer and text tools. JSON formatter, regex tester, case converter, lorem ipsum generator and more — private, fast, no signup."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-50 to-white py-20 dark:from-brand-950/50 dark:to-slate-950">
    <div class="container-wide text-center">
      <span class="inline-flex items-center gap-1 rounded-full bg-white px-3 py-1 text-xs font-medium text-brand-700 ring-1 ring-brand-200 shadow-sm dark:bg-slate-900 dark:text-brand-300 dark:ring-brand-900">
        <iconify-icon icon="lucide:zap" width="12" height="12"></iconify-icon>
        100% in your browser · No signup · No tracking
      </span>
      <h1 class="mt-6 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-slate-50">
        Free Online <span class="text-brand-600 dark:text-brand-400">Developer & Text Tools</span>
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
        Beautiful, fast, privacy-friendly online utilities for developers and content creators.
        Every tool runs entirely in your browser — your data never leaves your device.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="#tools" class="btn-primary">
          <iconify-icon icon="lucide:grid-3x3" width="16" height="16"></iconify-icon>
          Browse all tools
        </a>
        <a href="/blog" class="btn-secondary">
          <iconify-icon icon="lucide:book-open" width="16" height="16"></iconify-icon>
          Read the blog
        </a>
      </div>
    </div>

    <!-- Decorative grid -->
    <div class="absolute inset-0 -z-10 opacity-30 dark:opacity-10" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="0.5" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" class="text-slate-400 dark:text-slate-700" />
      </svg>
    </div>
  </section>

  <!-- Featured tools -->
  <section id="tools" class="container-wide py-16">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-50">
          <iconify-icon icon="lucide:sparkles" class="text-amber-500" width="22" height="22"></iconify-icon>
          Featured Tools
        </h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
          Hand-picked, most useful starters.
        </p>
      </div>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {featured.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>

  <!-- Categories -->
  <section class="bg-slate-50 py-16 dark:bg-slate-900/50">
    <div class="container-wide">
      {grouped.map(({ slug, meta, tools: categoryTools }) => (
        categoryTools.length > 0 && (
          <div class="mb-12 last:mb-0">
            <div class="flex items-center gap-3">
              <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-white text-brand-600 ring-1 ring-slate-200 dark:bg-slate-900 dark:ring-slate-800">
                <iconify-icon icon={`lucide:${meta.icon}`} width="18" height="18"></iconify-icon>
              </span>
              <div>
                <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-50">
                  <a href={`/category/${slug}`} class="hover:text-brand-700 dark:hover:text-brand-300">{meta.label}</a>
                </h2>
                <p class="text-sm text-slate-600 dark:text-slate-400">{meta.description}</p>
              </div>
            </div>
            <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {categoryTools.map((tool) => <ToolCard tool={tool} size="compact" />)}
            </div>
          </div>
        )
      ))}
    </div>
  </section>

  <!-- Why UtilHub -->
  <section class="container-wide py-16">
    <h2 class="text-center text-2xl font-bold text-slate-900 dark:text-slate-50">
      Why UtilHub?
    </h2>
    <p class="mx-auto mt-2 max-w-2xl text-center text-slate-600 dark:text-slate-300">
      Built for speed, privacy and simplicity. No account required, ever.
    </p>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <div class="card text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-300">
          <iconify-icon icon="lucide:shield-check" width="22" height="22"></iconify-icon>
        </div>
        <h3 class="mt-3 font-semibold text-slate-900 dark:text-slate-100">Private</h3>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
          Every tool runs in your browser. Your data is never uploaded to a server.
        </p>
      </div>
      <div class="card text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-amber-100 text-amber-600 dark:bg-amber-900/30 dark:text-amber-300">
          <iconify-icon icon="lucide:zap" width="22" height="22"></iconify-icon>
        </div>
        <h3 class="mt-3 font-semibold text-slate-900 dark:text-slate-100">Fast</h3>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
          Static site on the edge — pages load instantly anywhere in the world.
        </p>
      </div>
      <div class="card text-center">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-sky-100 text-sky-600 dark:bg-sky-900/30 dark:text-sky-300">
          <iconify-icon icon="lucide:heart" width="22" height="22"></iconify-icon>
        </div>
        <h3 class="mt-3 font-semibold text-slate-900 dark:text-slate-100">Free Forever</h3>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
          No paywall, no signup, no usage limits. Funded by lightweight ads when traffic grows.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
