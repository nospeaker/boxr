---
import ToolLayout from '~/layouts/ToolLayout.astro';

const SAMPLE = `[
  { "name": "Alice", "age": 30, "city": "NYC", "active": true },
  { "name": "Bob", "age": 25, "city": "LA", "active": false },
  { "name": "Carol", "age": 28, "city": "Chicago", "active": true }
]`;
---

<ToolLayout toolSlug="json-to-csv">
  <div class="mb-4 flex flex-wrap items-center gap-2">
    <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-200">
      <span>Delimiter:</span>
      <select id="delimiter-select" class="rounded-md border-slate-200 bg-white px-2 py-1 text-sm shadow-sm ring-1 ring-slate-200 dark:border-slate-700 dark:bg-slate-900 dark:ring-slate-700">
        <option value=",">Comma (CSV)</option>
        <option value="\t">Tab (TSV)</option>
        <option value=";">Semicolon</option>
        <option value="|">Pipe</option>
      </select>
    </label>
    <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-200">
      <input id="flatten" type="checkbox" class="h-4 w-4 rounded text-brand-600 focus:ring-brand-500" />
      Flatten nested objects
    </label>
    <div class="ml-auto flex items-center gap-2">
      <button id="copy-btn-wrapper" type="button" class="btn-ghost text-sm" data-copy-trigger>
        <iconify-icon icon="lucide:copy" width="14" height="14"></iconify-icon>
        Copy
      </button>
      <button id="download-btn" class="btn-primary text-sm">
        <iconify-icon icon="lucide:download" width="14" height="14"></iconify-icon>
        Download .csv
      </button>
      <button id="sample-btn" class="btn-ghost text-sm">Sample</button>
      <button id="clear-btn" class="btn-ghost text-sm">Clear</button>
    </div>
  </div>

  <div class="grid gap-4 lg:grid-cols-2">
    <div>
      <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">JSON Input</label>
      <textarea id="json-input" class="input-base scrollbar-thin mt-1 h-[420px] resize-y font-mono text-sm" placeholder='Paste a JSON array here...' spellcheck="false">{SAMPLE}</textarea>
    </div>
    <div>
      <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">CSV Output</label>
      <textarea id="csv-output" class="input-base scrollbar-thin mt-1 h-[420px] resize-y font-mono text-sm" readonly spellcheck="false"></textarea>
    </div>
  </div>

  <div id="status-bar" class="mt-3 text-xs text-slate-500 dark:text-slate-400"></div>

  <div id="error-banner" class="mt-3 hidden rounded-md bg-rose-50 p-3 text-sm text-rose-700 ring-1 ring-rose-200 dark:bg-rose-950 dark:text-rose-300 dark:ring-rose-900">
    <strong>Error:</strong> <span id="error-message"></span>
  </div>

  <Fragment slot="about">
    <p>
      Convert a JSON array into a CSV (Comma-Separated Values) file that you can open in
      Excel, Google Sheets, Numbers, or any data tool.
    </p>
    <ul>
      <li>✅ Auto-detects column names from JSON keys</li>
      <li>✅ Choose delimiter (comma / tab / semicolon / pipe)</li>
      <li>✅ Flattens nested objects using dot notation (<code>user.email</code>)</li>
      <li>✅ Proper CSV escaping for commas, quotes and newlines</li>
      <li>✅ One-click download as <code>.csv</code> file</li>
      <li>✅ All processing happens locally — your data is never uploaded</li>
    </ul>
  </Fragment>
</ToolLayout>

<script>
  import { jsonToCSV } from '~/tools/json-csv';

  const input = document.getElementById('json-input') as HTMLTextAreaElement;
  const output = document.getElementById('csv-output') as HTMLTextAreaElement;
  const errorBanner = document.getElementById('error-banner') as HTMLElement;
  const errorMessage = document.getElementById('error-message') as HTMLElement;
  const status = document.getElementById('status-bar') as HTMLElement;
  const delimiterSelect = document.getElementById('delimiter-select') as HTMLSelectElement;
  const flattenCheckbox = document.getElementById('flatten') as HTMLInputElement;
  const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement;
  const copyBtn = document.getElementById('copy-btn-wrapper') as HTMLButtonElement;
  const sampleBtn = document.getElementById('sample-btn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;

  const SAMPLE = `[
  { "name": "Alice", "age": 30, "city": "NYC", "active": true },
  { "name": "Bob", "age": 25, "city": "LA", "active": false },
  { "name": "Carol", "age": 28, "city": "Chicago", "active": true }
]`;

  function run() {
    const delimRaw = delimiterSelect.value;
    const delim = delimRaw === '\\t' ? '\t' : delimRaw;
    const result = jsonToCSV(input.value, {
      delimiter: delim,
      flattenNested: flattenCheckbox.checked,
    });
    if (result.error) {
      output.value = '';
      errorBanner.classList.remove('hidden');
      errorMessage.textContent = result.error ?? '';
      status.textContent = '❌ ' + (result.error || 'Error');
    } else {
      output.value = result.text;
      errorBanner.classList.add('hidden');
      status.textContent = `✓ ${result.rowCount} rows · ${result.columnCount} columns`;
    }
  }

  downloadBtn.addEventListener('click', () => {
    const blob = new Blob([output.value], { type: 'text/csv;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'data.csv';
    a.click();
    URL.revokeObjectURL(url);
  });

  copyBtn.addEventListener('click', async () => {
    await navigator.clipboard.writeText(output.value);
    const original = copyBtn.innerHTML;
    copyBtn.innerHTML = '<iconify-icon icon="lucide:check" width="14" height="14"></iconify-icon> Copied!';
    setTimeout(() => { copyBtn.innerHTML = original; }, 1200);
  });

  sampleBtn.addEventListener('click', () => { input.value = SAMPLE; run(); });
  clearBtn.addEventListener('click', () => { input.value = ''; run(); });

  [input, delimiterSelect, flattenCheckbox].forEach((el) => el.addEventListener('input', run));
  run();
</script>
