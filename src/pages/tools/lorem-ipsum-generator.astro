---
import ToolLayout from '~/layouts/ToolLayout.astro';
import CopyButton from '~/components/CopyButton.astro';
---

<ToolLayout toolSlug="lorem-ipsum-generator">
  <div class="mb-4 flex flex-wrap items-center gap-4">
    <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-200">
      <span>Count:</span>
      <input id="count-input" type="number" min="1" max="100" value="3" class="w-20 rounded-md border-slate-200 bg-white px-2 py-1 text-sm shadow-sm ring-1 ring-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500/30 dark:border-slate-700 dark:bg-slate-900 dark:ring-slate-700" />
    </label>
    <div class="flex gap-1 rounded-lg bg-slate-100 p-1 dark:bg-slate-800">
      <button data-unit="paragraphs" class="unit-btn px-3 py-1 text-sm font-medium rounded-md transition data-[active=true]:bg-white data-[active=true]:shadow dark:data-[active=true]:bg-slate-900">Paragraphs</button>
      <button data-unit="sentences" class="unit-btn px-3 py-1 text-sm font-medium rounded-md transition data-[active=true]:bg-white data-[active=true]:shadow dark:data-[active=true]:bg-slate-900">Sentences</button>
      <button data-unit="words" class="unit-btn px-3 py-1 text-sm font-medium rounded-md transition data-[active=true]:bg-white data-[active=true]:shadow dark:data-[active=true]:bg-slate-900">Words</button>
    </div>
    <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-200">
      <input id="start-lorem" type="checkbox" checked class="h-4 w-4 rounded text-brand-600 focus:ring-brand-500" />
      Start with "Lorem ipsum dolor sit amet"
    </label>
    <div class="ml-auto flex items-center gap-2">
      <CopyButton data-copy-target="lorem-output" />
      <button id="regen-btn" class="btn-secondary text-sm">
        <iconify-icon icon="lucide:refresh-cw" width="14" height="14"></iconify-icon>
        Regenerate
      </button>
    </div>
  </div>

  <textarea
    id="lorem-output"
    readonly
    spellcheck="false"
    class="input-base scrollbar-thin h-[420px] w-full resize-y"
  ></textarea>

  <div id="meta" class="mt-3 text-xs text-slate-500 dark:text-slate-400"></div>

  <Fragment slot="about">
    <p>Generate classic Lorem Ipsum placeholder text by paragraphs, sentences, or words — perfect for mockups, prototypes, layouts and design templates.</p>
    <ul>
      <li>✅ Choose between paragraphs / sentences / words</li>
      <li>✅ Optionally begin with the canonical "Lorem ipsum dolor sit amet"</li>
      <li>✅ Realistic sentence and paragraph rhythm</li>
      <li>✅ One-click copy and regenerate</li>
      <li>✅ Pure JavaScript — runs entirely in your browser</li>
    </ul>
  </Fragment>
</ToolLayout>

<script>
  import { generateLorem } from '~/tools/lorem';

  const countInput = document.getElementById('count-input') as HTMLInputElement;
  const startLorem = document.getElementById('start-lorem') as HTMLInputElement;
  const output = document.getElementById('lorem-output') as HTMLTextAreaElement;
  const regenBtn = document.getElementById('regen-btn') as HTMLButtonElement;
  const meta = document.getElementById('meta') as HTMLElement;

  const unitButtons = document.querySelectorAll<HTMLButtonElement>('.unit-btn');
  let activeUnit: 'paragraphs' | 'sentences' | 'words' = 'paragraphs';

  unitButtons.forEach((btn) => {
    if (btn.dataset.unit === activeUnit) btn.dataset.active = 'true';
    btn.addEventListener('click', () => {
      unitButtons.forEach((b) => delete b.dataset.active);
      btn.dataset.active = 'true';
      activeUnit = btn.dataset.unit as typeof activeUnit;
      run();
    });
  });

  function run() {
    const count = Math.max(1, Math.min(100, parseInt(countInput.value, 10) || 3));
    const text = generateLorem({
      count,
      unit: activeUnit,
      startWithLorem: startLorem.checked,
    });
    output.value = text;
    const words = text.split(/\s+/).filter(Boolean).length;
    const chars = text.length;
    meta.textContent = `${count} ${activeUnit} · ${words} words · ${chars} characters`;
  }

  [countInput, startLorem].forEach((el) => el.addEventListener('input', run));
  regenBtn.addEventListener('click', run);
  run();
</script>
