---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="container-narrow py-12">
    <nav class="text-sm text-slate-500 dark:text-slate-400">
      <a href="/" class="hover:text-brand-600 dark:hover:text-brand-300">Home</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="hover:text-brand-600 dark:hover:text-brand-300">Blog</a>
      <span class="mx-2">/</span>
      <span class="text-slate-700 dark:text-slate-300">{post.data.title}</span>
    </nav>

    <header class="mt-4">
      <span class="text-xs font-medium text-brand-600 dark:text-brand-400">{post.data.category}</span>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-50">
        {post.data.title}
      </h1>
      <div class="mt-3 text-sm text-slate-500 dark:text-slate-400">
        <time datetime={post.data.publishedAt.toISOString()}>
          {post.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
        </time>
        · {post.data.readingTime} min read
      </div>
    </header>

    <div class="prose prose-slate max-w-none dark:prose-invert mt-8 prose-headings:font-semibold prose-a:text-brand-600 prose-a:no-underline hover:prose-a:underline dark:prose-a:text-brand-300">
      <Content />
    </div>
  </article>
</BaseLayout>
