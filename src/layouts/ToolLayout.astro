---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ToolCard from '~/components/ToolCard.astro';
import { tools, getTool } from '~/config/tools';

interface Props {
  toolSlug: string;
}

const { toolSlug } = Astro.props;
const tool = getTool(toolSlug)!;
const related = tools.filter((t) => t.slug !== toolSlug).slice(0, 4);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: tool.title,
    url: new URL(`/tools/${tool.slug}`, Astro.site).toString(),
    description: tool.metaDescription,
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: `Is ${tool.title} free?`,
        acceptedAnswer: {
          '@type': 'Answer',
          text: `Yes, ${tool.title} is 100% free to use. There is no signup, no limit and no tracking. Your data never leaves your browser.`,
        },
      },
      {
        '@type': 'Question',
        name: `Is my data safe when using ${tool.title}?`,
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Absolutely. All processing happens locally in your browser. We never upload, store, or log your input data.',
        },
      },
    ],
  },
];
---

<BaseLayout
  title={tool.title}
  description={tool.metaDescription}
  jsonLd={jsonLd}
>
  <section class="bg-gradient-to-b from-brand-50/50 to-transparent py-12 dark:from-brand-950/30">
    <div class="container-narrow">
      <nav class="mb-4 text-sm text-slate-500 dark:text-slate-400">
        <a href="/" class="hover:text-brand-600 dark:hover:text-brand-300">Home</a>
        <span class="mx-2">/</span>
        <a href="/category/developer" class="hover:text-brand-600 dark:hover:text-brand-300">{tool.category}</a>
        <span class="mx-2">/</span>
        <span class="text-slate-700 dark:text-slate-300">{tool.title}</span>
      </nav>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-50">
        {tool.title}
      </h1>
      <p class="mt-3 text-lg text-slate-600 dark:text-slate-300">
        {tool.description}
      </p>
    </div>
  </section>

  <section class="container-narrow -mt-6 pb-20">
    <div class="card animate-fade-in">
      <slot />
    </div>

    <details class="mt-8 group rounded-2xl ring-1 ring-slate-200 bg-white p-5 dark:ring-slate-800 dark:bg-slate-900">
      <summary class="flex cursor-pointer items-center justify-between font-semibold text-slate-900 dark:text-slate-100">
        <span class="flex items-center gap-2">
          <iconify-icon icon="lucide:info" class="text-brand-600" width="18" height="18"></iconify-icon>
          About this tool
        </span>
        <iconify-icon icon="lucide:chevron-down" class="transition group-open:rotate-180" width="18" height="18"></iconify-icon>
      </summary>
      <div class="prose prose-slate dark:prose-invert mt-4 max-w-none text-sm">
        <slot name="about" />
      </div>
    </details>

    <section class="mt-12">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100">Related Tools</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {related.map((t) => <ToolCard tool={t} size="compact" />)}
      </div>
    </section>
  </section>
</BaseLayout>
